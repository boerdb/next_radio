# Azuracast basis-URL
NEXT_PUBLIC_AZURACAST_URL=https://benswebradio.nl

# OpenWeather API key (server-side only) — gedeeld met je energie-app?
# Radio-app: max ~96 calls/dag (15 min server-cache). Jouw verbruik is nu ~25/dag.
OPENWEATHER_API_KEY=your_openweather_api_key_here

# Optioneel: eigen weericonen (static), zie public/weather-icons/README.md
# Productie via Cloudflare tunnel o.a. https://app.benswebradio.nl
# NEXT_PUBLIC_WEATHER_ICON_BASE_URL=https://app.benswebradio.nl/weather-icons
# NEXT_PUBLIC_WEATHER_ICON_EXT=png
# NEXT_PUBLIC_WEATHER_ICON_URL_TEMPLATE=https://app.benswebradio.nl/weather-icons/{icon}.png
